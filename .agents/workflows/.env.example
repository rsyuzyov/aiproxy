# Параметры для e2e-тестов AIProxy в LXC.
# Скопируй в .env и подправь под свой стенд:
#   cp .agents/workflows/.env.example .agents/workflows/.env

# --- Proxmox / контейнер ---
PVE_HOST=pve1.som.local
CT_ID=123
ZFS_POOL=zpool
SNAPSHOT=s20260318

# --- Создание контейнера (только для e2e-test-lxc-createlxc) ---
CT_HOSTNAME=aiproxy1
CT_MEMORY=512
CT_SWAP=512
CT_CORES=1
CT_ROOTFS_GB=8
CT_BRIDGE=vmbr0
# Шаблон ищется по шаблону 'debian-13' в локальном хранилище
CT_TEMPLATE_PATTERN=debian-13

# --- Git / установка ---
REPO_URL=https://github.com/rsyuzyov/aiproxy.git
BRANCH=gost
COMPONENTS="--lxqt --xrdp --proxybridge --cliproxy --9router --firefox"
TIMEOUT=6m
